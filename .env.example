# Neon Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Auth.js v5
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Vercel Blob (file uploads)
BLOB_READ_WRITE_TOKEN=

# Pusher Channels (real-time, optional — gated on REALTIME_ENABLED)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
REALTIME_ENABLED=false

# Seed (used by `pnpm db:seed`)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# AI features (chunks 13–14 — features no-op cleanly when absent)
ANTHROPIC_API_KEY=
VALYU_API_KEY=
AI_DAILY_SPEND_CAP_USD=5
